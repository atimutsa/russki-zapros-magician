```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
coverage/
htmlcov/
.nyc_output/

# Environment variables
.env
.env.local
.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled files
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo

# System files
.DS_Store
Thumbs.db

# Testing
.mypy_cache/
.pytest_cache/
.jest/
nyc_output/

# Gradle
.gradle/
build/

# Maven
target/

# Temporary files
tmp/
temp/
```